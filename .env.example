# Copy this file to .env and fill in your values.
# .env is gitignored. Read by the local utility scripts at startup.

GOOGLE_DRIVE_FOLDER_ID=your-drive-folder-id-here

# Needed only by diagnose_cache.py (live thum.io capture).
# Use the same value that's set on Render.
THUM_AUTH=your-thum-io-auth-key-here
